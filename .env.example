# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Beehiiv API key — app.beehiiv.com → Settings → API
BEEHIIV_API_KEY=your_beehiiv_api_key_here

# Beehiiv Publication ID — app.beehiiv.com → Settings → Publication
BEEHIIV_PUB_ID=pub_xxxxxxxx

# Logo URL — after pushing to GitHub, set this to:
# https://raw.githubusercontent.com/YOUR_USERNAME/YOUR_REPO/main/static/logo.png
LOGO_URL=
