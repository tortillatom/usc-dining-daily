# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Brevo (Sendinblue) API key — https://app.brevo.com/settings/keys/api
BREVO_API_KEY=your_brevo_api_key_here

# Brevo contact list ID (found in Contacts → Lists → click a list → the ID is in the URL)
BREVO_LIST_ID=1

# Sender identity (must be a verified sender in your Brevo account)
SENDER_EMAIL=dining@yourdomain.com
SENDER_NAME=USC Dining Daily

# Logo URL — after pushing to GitHub, set this to:
# https://raw.githubusercontent.com/YOUR_USERNAME/YOUR_REPO/main/static/logo.png
LOGO_URL=
